# Docker Compose local defaults. Replace these values outside local demonstration use.
POSTGRES_PASSWORD=airlock-local-only
AIRLOCK_REPORT_SIGNING_SECRET=demo-signing-secret-change-me
AIRLOCK_RETENTION_DAYS=30

# Direct backend execution defaults to SQLite for low-friction local development.
AIRLOCK_DATABASE_URL=sqlite:///./data/airlock.db
AIRLOCK_AUTO_CREATE_SCHEMA=true
AIRLOCK_QUARANTINE_DIR=./quarantine
AIRLOCK_MAX_FILE_SIZE_MB=5
AIRLOCK_CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
